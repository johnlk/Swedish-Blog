---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

import '../styles/global.css';

const base = import.meta.env.BASE_URL;
const { title, description = "Photos, videos, stories of my trip abroad.", image = `${base}images/img_0514_low.JPG` } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:type" content="website" />
    <link rel="sitemap" href={`${base}sitemap-index.xml`} />
  </head>
  <body>
    <div class="site-container">
      <header class="site-header">
        <h1><a href={`${base}`}>Swedish Blog</a></h1>
        <nav class="site-nav">
          <a href={`${base}`}>Home</a>
          <a href={`${base}gallery/`}>Trip Images</a>
        </nav>
      </header>

      <main>
        <slot />
      </main>

      <footer class="site-footer">
        John Kuhn &middot; Uppsala, Sweden &middot; 2018
      </footer>
    </div>
  </body>
</html>
