---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');

// Sort by date
allPosts.sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

// Group by month
const months: Record<string, typeof allPosts> = {};
for (const post of allPosts) {
  const date = new Date(post.data.date);
  const monthKey = date.toLocaleString('en-US', { month: 'long', year: 'numeric' });
  if (!months[monthKey]) months[monthKey] = [];
  months[monthKey].push(post);
}

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Swedish Blog - John Kuhn">
  <img
    class="hero-image"
    src={`${base}images/img_0461_low.JPG`}
    alt="Sweden landscape"
  />

  <div class="intro">
    <span class="greeting">Hej!</span>
    Welcome to John Kuhn's study abroad blog. This blog is a way for me to answer
    the questions that my family and friends constantly have about my trip. It also
    serves as a platform for me to reflect on my trip when it concludes and reminisce
    about the day-to-day events.
  </div>

  <section class="post-list-section" id="posts">
    <h2>Blog Posts</h2>
    {Object.entries(months).map(([month, posts]) => (
      <div class="month-group">
        <h3>{month}</h3>
        {posts.map((post) => (
          <a href={`${base}posts/${post.id}/`}>{post.data.title}</a>
        ))}
      </div>
    ))}
  </section>
</BaseLayout>
